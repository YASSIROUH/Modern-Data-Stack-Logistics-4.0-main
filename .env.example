# ==============================================================================
# LOGISTICS 4.0 CONTROL TOWER - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and configure your local settings.
# DO NOT commit the .env file to version control.

# --- Database / Data Warehouse ---
POSTGRES_USER=admin_logistics
POSTGRES_PASSWORD=securepassword123
POSTGRES_DB=logistics_db
POSTGRES_PORT=5432

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=pfa2026
MINIO_BROWSER_REDIRECT_URL=http://localhost:8000/minio
MINIO_VOLUMES=/data

# --- Message Broker (Kafka/Zookeeper) ---
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- MLOps (MLflow) ---
MLFLOW_BACKEND_STORE_URI=sqlite:////opt/mlflow/mlruns/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=/opt/mlflow/mlruns

# --- Observability (Grafana/Loki) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost:8000/grafana/

# --- Orchestration (Airflow) ---
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
